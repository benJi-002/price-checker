TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE
TELEGRAM_CHAT_ID=PUT_YOUR_CHAT_ID_HERE

CHECK_INTERVAL_MINUTES=30
DB_PATH=./prices.db

USER_AGENT=Mozilla/5.0 (Linux; Android 8; Xiaomi Mi 5)

# Send one startup status message when service starts and products exist.
SEND_STARTUP_MESSAGE=1

# If 1 and there are no valid active products, service sends stop reason and exits.
# If 0, service keeps running silently until products appear.
STOP_ON_EMPTY_PRODUCTS=0

# Cooldown for duplicate service alerts (startup/stop/fatal), in minutes.
SERVICE_ALERT_COOLDOWN_MINUTES=120
